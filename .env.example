# -----------------------------------------------------------------------------
# Vaani Configuration Template
# Copy this file to '.env' and modify values as needed for your local setup.
# -----------------------------------------------------------------------------

# Whisper speech-to-text model size. Options: tiny, base, small, medium, large-v2
# Higher sizes are more accurate but slower and consume more memory/CPU.
VAANI_WHISPER_MODEL=medium

# Audio sample rate in Hz (16000 is standard and required by Whisper/VAD)
VAANI_SAMPLE_RATE=16000

# Voice Activity Detector aggressiveness (0 to 3)
# 0: Normal, 1: Low filtering, 2: Moderate, 3: Aggressive (strictest silence detection)
VAANI_VAD_AGGRESSIVENESS=2

# Duration of continuous silence (in milliseconds) before recording auto-stops
VAANI_SILENCE_MS=600

# Directory where offline models (Whisper and translation models) will be downloaded and cached
VAANI_MODELS_DIR=./models

# Hard cap limit on recording length (in seconds) to prevent infinite loops or memory bloat
VAANI_MAX_RECORD_SECONDS=15

# Minimum confidence threshold (0.0 to 1.0) for language detection.
# Transcriptions below this threshold will raise a LowConfidenceError.
VAANI_TRANSLATION_CONFIDENCE_THRESHOLD=0.6

# -----------------------------------------------------------------------------
# Local Ollama Chatbot Integration Settings
# -----------------------------------------------------------------------------
# Base URL where local Ollama API service is running
VAANI_OLLAMA_URL=http://localhost:11434

# Name of the local LLM model pulled via Ollama (e.g. qwen2.5:1.5b, llama3:8b)
VAANI_OLLAMA_MODEL=qwen2.5:1.5b

